{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:rms:schema:implementation:v0.1",
  "title": "RMS Implementation Binding v0.1",
  "type": "object",
  "required": [
    "spec",
    "module",
    "binding",
    "source",
    "commands"
  ],
  "properties": {
    "spec": {
      "const": "rms/implementation/v0.1"
    },
    "module": {
      "type": "string",
      "minLength": 1
    },
    "binding": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": [
        "root",
        "public_entrypoint"
      ],
      "properties": {
        "root": {
          "type": "string"
        },
        "public_entrypoint": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "commands": {
      "type": "object",
      "required": [
        "build",
        "verify"
      ],
      "properties": {
        "build": {
          "type": "string"
        },
        "verify": {
          "type": "string"
        },
        "format": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "architecture": {
      "type": "object",
      "additionalProperties": true
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": true
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": true
    },
    "permissions": {
      "type": "object",
      "additionalProperties": true
    },
    "semantic_functions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/semanticFunction"
      }
    },
    "generated": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "patternProperties": {
    "^x-": {}
  },
  "additionalProperties": false,
  "$defs": {
    "semanticFunction": {
      "type": "object",
      "required": [
        "id",
        "symbol",
        "kind"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "constructor",
            "parser",
            "decision",
            "transition",
            "projector",
            "adapter",
            "interpreter"
          ]
        },
        "purity": {
          "enum": [
            "pure",
            "effectful",
            "boundary"
          ]
        },
        "discharges": {
          "type": "object",
          "properties": {
            "contracts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "invariants": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "assumptions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        },
        "assumptions": {
          "type": "object",
          "properties": {
            "requires": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "maintains": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "ensures": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        },
        "evidence": {
          "type": "object",
          "properties": {
            "laws": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "contracts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "scenarios": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "boundaries": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
